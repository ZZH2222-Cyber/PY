## Copy to .env and fill in values

## Copy to .env and fill in values

# Base URL of backend
# 本地快速验证可用 https://httpbin.org（示例接口 /get /post /put /delete）
BASE_URL=https://httpbin.org

# Optional: API Key auth (auto-injected into every request)
# Bearer style authentication
API_KEY=
API_KEY_HEADER=Authorization
API_KEY_PREFIX=Bearer

# DeepSeek (AI test-case generation)
# 注意：这是 DeepSeek 的密钥，变量名必须是 DEEPSEEK_API_KEY
DEEPSEEK_API_KEY="deepseek密钥"
# 如无需自定义，保持默认即可（见 config/settings.py）
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

