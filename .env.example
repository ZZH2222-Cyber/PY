## Copy to .env and fill in values

# Base URL of backend
BASE_URL=https://your-backend.example.com

# Optional: API Key auth (auto-injected into every request)
# X-API-Key style:
API_KEY=
API_KEY_HEADER=X-API-Key
API_KEY_PREFIX=

# Or Bearer style:
# API_KEY_HEADER=Authorization
# API_KEY_PREFIX=Bearer

